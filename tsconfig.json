{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": false,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@world": ["src/world/index.ts"],
      "@world/*": ["src/world/*"],
      "@engine": ["src/engine/index.ts"],
      "@engine/*": ["src/engine/*"],
      "@ai": ["src/ai/index.ts"],
      "@ai/*": ["src/ai/*"],
      "@assets": ["src/assets/index.ts"],
      "@assets/*": ["src/assets/*"],
      "@scene": ["src/scene/index.ts"],
      "@scene/*": ["src/scene/*"],
      "@audio": ["src/audio/index.ts"],
      "@audio/*": ["src/audio/*"],
      "@store": ["src/store/index.ts"],
      "@store/*": ["src/store/*"],
      "@platform": ["src/platform/index.ts"],
      "@platform/*": ["src/platform/*"],
      "@workers/*": ["src/workers/*"],
      "@shared": ["src/shared/index.ts"],
      "@shared/*": ["src/shared/*"],
      "@views": ["app/views/index.ts"],
      "@views/*": ["app/views/*"],
      "@components": ["app/components/index.ts"],
      "@components/*": ["app/components/*"],
      "@atoms": ["app/atoms/index.ts"],
      "@atoms/*": ["app/atoms/*"],
      "@hooks": ["app/hooks/index.ts"],
      "@hooks/*": ["app/hooks/*"],
      "@app/*": ["app/*"],
      "@logic/*": ["src/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "include": ["app", "src", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}

{
  "name": "voxel-realms",
  "version": "0.2.1",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/prepare-web-sqlite.mjs",
    "prebuild": "node scripts/prepare-web-sqlite.mjs",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/copy-public-assets.mjs && jiti scripts/verify-runtime-assets.ts --dist && jiti scripts/verify-build-budget.ts",
    "preview": "vite preview --host 0.0.0.0",
    "test": "pnpm test:visual-verifier && vitest run app src && pnpm realm:verify-visual",
    "test:browser": "vitest run app && pnpm realm:verify-visual",
    "test:golden": "vitest run app/games/voxel-realms/Game.test.tsx -t \"deterministic golden path\" && pnpm realm:verify-visual",
    "test:visual-verifier": "jiti scripts/test-visual-manifest-verifier.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=1 playwright test --project=desktop-chromium",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .vitest-attachments test-screenshots",
    "realm:validate": "jiti scripts/validate-realms.ts",
    "realm:verify-visual": "jiti scripts/verify-visual-manifest.ts",
    "realm:assets": "jiti scripts/report-realm-assets.ts",
    "build:verify-budget": "jiti scripts/verify-build-budget.ts",
    "assets:chaos-slice": "node scripts/generate-chaos-slice.mjs",
    "assets:chaos-glb": "node scripts/convert-chaos-slice-gltf-to-glb.mjs",
    "assets:static-variants": "node scripts/generate-static-variants.mjs",
    "assets:verify-runtime": "jiti scripts/verify-runtime-assets.ts",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/rapier": "^2.2.0",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "lucide-react": "^1.9.0",
    "mitt": "^3.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "1.11.0",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.184.0",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "yuka": "^0.7.8"
  }
}

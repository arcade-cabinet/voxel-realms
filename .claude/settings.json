{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-write-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/keep-going.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-batch-flush.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(jiti *)",
      "Bash(xvfb-run *)",
      "Bash(./gradlew *)",
      "Bash(cd android *)",
      "Bash(cd ios *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git remote*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin *)",
      "Bash(git push -u origin *)",
      "Bash(git push --force-with-lease origin *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git reset --soft *)",
      "Bash(git reset --mixed *)",
      "Bash(git reset HEAD*)",
      "Bash(git pull --ff-only*)",
      "Bash(git pull origin *)",
      "Bash(git tag*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh workflow *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(gh release *)",
      "Bash(gh label *)",
      "Bash(gh repo view*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm -f *)",
      "Bash(rm -rf dist*)",
      "Bash(rm -rf coverage*)",
      "Bash(rm -rf test-results*)",
      "Bash(rm -rf playwright-report*)",
      "Bash(rm -rf .vitest-attachments*)",
      "Bash(rm -rf test-screenshots*)",
      "Bash(chmod +x *)",
      "Bash(openssl rand *)",
      "Bash(date *)",
      "Bash(env *)",
      "Bash(which *)",
      "Bash(sleep *)",
      "Bash(printf *)",
      "Bash(echo *)",
      "Bash(python3 -c *)",
      "Bash(touch *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease main)",
      "Bash(git push --force-with-lease origin main)",
      "Bash(gh pr merge * --admin *)",
      "Bash(gh pr merge *--admin*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ~/.ssh*)",
      "Bash(git config --global *)",
      "Bash(git reset --hard main)",
      "Bash(git reset --hard origin/main*--no-verify*)"
    ]
  },
  "env": {
    "VOXEL_REALMS_AUTONOMOUS": "1",
    "BATCH_PRD": "docs/plans/voxel-realms-1.0.prq.md",
    "BATCH_TRACKER": "docs/plans/batch-tracker.md"
  }
}
